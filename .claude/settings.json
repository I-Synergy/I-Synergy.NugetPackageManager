{
  "plansDirectory": "./.claude/plans",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npm run esbuild 2>&1 | tail -3"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "statusMessage": "Regenerating screenshots and demo GIF...",
            "command": "jq -r '.tool_input.command' | { read -r cmd; echo \"$cmd\" | grep -q 'git commit' && git diff HEAD~1 --name-only 2>/dev/null | grep -qE '^(src/|tools/mock-api)' && cd \"D:/Projects/Github/I-Synergy.NugetPackageManager\" && npm run docs; } 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "Read",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf:*)"
    ],
    "additionalDirectories": [
      "./.claude",
      "./.claude/analysis",
      "./.claude/checklists",
      "./.claude/completed",
      "./.claude/patterns",
      "./.claude/plans",
      "./.claude/progress",
      "./.claude/project",
      "./.claude/reference",
      "./.claude/skills"
    ]
  }
}
